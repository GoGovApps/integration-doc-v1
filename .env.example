# Copy this file to .env and edit as needed: `cp .env.example .env`

# Port the server listens on.
PORT=3000

# Authentication mode the server enforces. One of: apikey, basic
AUTH_MODE=apikey

# Used when AUTH_MODE=apikey. Sent by the caller as the `X-API-Key` header.
API_KEY=demo-key-change-me

# Used when AUTH_MODE=basic. Sent by the caller as `Authorization: Basic <base64(user:pass)>`.
BASIC_USER=demo
BASIC_PASS=change-me

# Maximum requests per minute per client IP before responding with 429.
RATE_LIMIT_PER_MINUTE=60
